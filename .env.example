# ────────────────────────────────────────────────────────
# LocalConnect — Environment Configuration
# Copy to .env and fill in real values before production
# ────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────
# REQUIRED in production — used to sign JWTs
SECRET_KEY=your-secret-key-here-change-in-production

# Environment: development | staging | production
ENVIRONMENT=development

# Database (use PostgreSQL in production)
DATABASE_URL=sqlite:///./localconnect.db
# DATABASE_URL=postgresql://user:password@localhost:5432/localconnect

# CORS: comma-separated frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_AI=10/minute

# ── Paynow (REQUIRED for payments) ──────────────────────
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RETURN_URL=http://localhost:5173/payment-return
PAYNOW_RESULT_URL=http://localhost:8000/api/payments/update

# ── Google Gemini AI ─────────────────────────────────────
GOOGLE_API_KEY=

# ── Docker Compose defaults ──────────────────────────────
DB_PASSWORD=localconnect_dev

# ── Frontend (.env at project root) ─────────────────────
VITE_API_URL=http://localhost:8000/api
